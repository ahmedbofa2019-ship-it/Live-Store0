{
  "version": 2,
  "builds": [
    { "src": "register.js", "use": "@vercel/node" },
    { "src": "login.js", "use": "@vercel/node" },
    { "src": "item.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/register", "dest": "register.js" },
    { "src": "/api/login", "dest": "login.js" },
    { "src": "/api/item", "dest": "item.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}